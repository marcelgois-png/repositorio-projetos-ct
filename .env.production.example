# Ambiente de producao
# Copie este arquivo para .env no servidor e preencha os valores reais.

# Django / seguranca
DJANGO_SECRET_KEY=gere-uma-chave-longa-aleatoria-com-50-ou-mais-caracteres
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=projetos.ct.ufpb.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://projetos.ct.ufpb.br
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Banco de dados MySQL
MYSQL_DATABASE=repo_arquitetonico_prod
MYSQL_USER=repo_arquitetonico_user
MYSQL_PASSWORD=troque-por-senha-forte-do-usuario
MYSQL_ROOT_PASSWORD=troque-por-senha-forte-do-root
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Arquivos e uploads dentro dos containers
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_ROOT=/app/media
DJANGO_PRIVATE_MEDIA_ROOT=/app/private_media
DJANGO_MAX_UPLOAD_MB=200
DJANGO_PASSWORD_RESET_TIMEOUT_SECONDS=1800

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# E-mail institucional
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=Repositorio CT/UFPB <nao-responda@ct.ufpb.br>
DJANGO_EMAIL_HOST=smtp.exemplo.ufpb.br
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=usuario-smtp
DJANGO_EMAIL_HOST_PASSWORD=senha-smtp
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_USE_SSL=0
